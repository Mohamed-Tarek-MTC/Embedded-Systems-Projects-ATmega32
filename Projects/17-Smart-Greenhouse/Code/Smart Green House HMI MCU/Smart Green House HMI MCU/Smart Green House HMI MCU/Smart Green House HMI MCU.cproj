      <SubType>compile</SubType>
    </Compile>
    <Compile Include="KeyPad.c">
      <SubType>compile</SubType>
    </Compile>
    <Compile Include="KeyPad.h">
      <SubType>compile</SubType>
    </Compile>
    <Compile Include="LCD20x4.c">
      <SubType>compile</SubType>
    </Compile>
    <Compile Include="LCD20x4.h">
      <SubType>compile</SubType>
    </Compile>
    <Compile Include="LCDconfig.h">
      <SubType>compile</SubType>
    </Compile>
    <Compile Include="Plant_Config.c">
      <SubType>compile</SubType>
    </Compile>
    <Compile Include="Plant_Config.h">
      <SubType>compile</SubType>
    </Compile>
    <Compile Include="Smart Green House HMI MCU.c">
      <SubType>compile</SubType>
    </Compile>
    <Compile Include="Standard_Macros.h">
      <SubType>compile</SubType>
    </Compile>
    <Compile Include="Timers.c">
